<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_transactions_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_bg_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="LitFinance" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Últimos movimientos"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_refresh_txns"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/stat_notify_sync"
            android:contentDescription="Refresh"
            android:tint="#80FFFFFF" />
    </LinearLayout>

    <!-- Transaction row 1 -->
    <LinearLayout
        android:id="@+id/txn_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/widget_txn_row_bg"
        android:visibility="gone">

        <TextView
            android:id="@+id/txn_icon_1"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="💸"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/txn_concept_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Concepto"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/txn_date_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txn_amount_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0.00"
            android:textColor="#EF4444"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Transaction row 2 -->
    <LinearLayout
        android:id="@+id/txn_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/widget_txn_row_bg"
        android:visibility="gone">

        <TextView
            android:id="@+id/txn_icon_2"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="💸"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/txn_concept_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Concepto"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/txn_date_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txn_amount_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0.00"
            android:textColor="#EF4444"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Transaction row 3 -->
    <LinearLayout
        android:id="@+id/txn_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/widget_txn_row_bg"
        android:visibility="gone">

        <TextView
            android:id="@+id/txn_icon_3"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="💸"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/txn_concept_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Concepto"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/txn_date_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txn_amount_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0.00"
            android:textColor="#EF4444"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/txn_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Sin movimientos recientes"
        android:textColor="#666666"
        android:textSize="12sp"
        android:visibility="visible" />

</LinearLayout>
